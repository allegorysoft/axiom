    "react-dom": "^19"
  },
  "devDependencies": {
    "@tailwindcss/vite": "~4.3.0",
    "tailwindcss": "~4.3.0",
    "@nx/vite": "~22.7.0",
    "glob":"latest"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5",
    "class-variance-authority": "~0.7.0",
    "clsx": "~2.1.0",
    "lucide-react": "~1.17.0",
    "radix-ui": "~1.5.0",
    "shadcn": "~4.13.0",
    "tailwind-merge": "~3.6.0",
    "tw-animate-css": "~1.4.0"
  }
