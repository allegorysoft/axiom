{
  "name": "@axiomframework/react-theme",
  "type": "module",
  "version": "0.0.1-alpha.0",
  "description": "Axiom framework react-ui theme package",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/allegorysoft/axiom.git",
    "directory": "npm/react/libs/theme"
  },
  "homepage": "https://axiomframework.dev",
  "author": "Allegorysoft",
  "main": "./index.js",
  "types": "./index.d.ts",
  "sideEffects": ["**/*.css"],
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.js",
      "style": "./index.css"
    },
    "./components": {
      "types": "./components/index.d.ts",
      "import": "./components/index.js"
    },
    "./index.css": "./src/styles/index.css"
  },
  "peerDependencies": {
    "react": "catalog:",
    "react-dom": "catalog:"
  },
  "devDependencies": {
    "@tailwindcss/vite": "catalog:",
    "tailwindcss": "catalog:"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5",
    "class-variance-authority": "~0.7.0",
    "clsx": "catalog:",
    "lucide-react": "catalog:",
    "@base-ui/react": "catalog:",
    "shadcn": "catalog:",
    "tailwind-merge": "~3.6.0",
    "tw-animate-css": "~1.4.0"
  }
}
